# Server Configuration
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# Database Configuration
DATABASE_URL="postgresql://postgres:xuv700@localhost:5432/pms_database?schema=public"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# Backup Configuration (for backup script)
BACKUP_PATH=/var/backups/pms
BACKUP_RETENTION_DAYS=30
